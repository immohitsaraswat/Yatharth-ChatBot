rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow website to create appointments and career applications
    match /appointments/{appointment} {
      allow create: if true; 
      allow read: if false; // Only admin via Firebase console/Admin SDK
    }
    
    match /careers/{application} {
      allow create: if true;
      allow read: if false;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
